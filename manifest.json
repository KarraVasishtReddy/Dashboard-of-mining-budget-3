{
  "name": "TJBNSCM Mining Operations",
  "short_name": "TJBNSCM",
  "description": "Daily operations dashboard for Takli Jena Coal Mine. Track shift production, HEMM machine performance, OPEX costs and hindrance logs. Works fully offline.",
  "id": "Miningengineer.TJBNSCMMiningOperations",
  "start_url": "https://karravasishtreddy.github.io/Dashboard-of-mining-budget-3/",
  "scope": "/Dashboard-of-mining-budget-3/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "orientation": "any",
  "background_color": "#07090f",
  "theme_color": "#f59e0b",
  "lang": "en",
  "dir": "ltr",
  "categories": ["productivity", "business", "utilities"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "icons/icon-48x48.png",   "sizes": "48x48",   "type": "image/png", "purpose": "any" },
    { "src": "icons/icon-72x72.png",   "sizes": "72x72",   "type": "image/png", "purpose": "any" },
    { "src": "icons/icon-96x96.png",   "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "icons/icon-144x144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "icons/icon-180x180.png", "sizes": "180x180", "type": "image/png", "purpose": "any" },
    { "src": "icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "screenshots": [
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "TJBNSCM Mining Operations Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Daily Entry",
      "short_name": "Daily",
      "description": "Enter today's shift production and machine data",
      "url": "/Dashboard-of-mining-budget-3/#daily",
      "icons": [{ "src": "icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Live operations analytics",
      "url": "/Dashboard-of-mining-budget-3/#dashboard",
      "icons": [{ "src": "icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Historical Reports",
      "short_name": "History",
      "description": "HEMM, OPEX and production history",
      "url": "/Dashboard-of-mining-budget-3/#historical",
      "icons": [{ "src": "icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Import Data",
      "short_name": "Import",
      "description": "Restore JSON backup or import Excel data",
      "url": "/Dashboard-of-mining-budget-3/#export",
      "icons": [{ "src": "icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/Dashboard-of-mining-budget-3/#export",
      "accept": {
        "application/json": [".json"],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"],
        "application/vnd.ms-excel": [".xls"]
      },
      "icons": [{ "src": "icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 480
  }
}
